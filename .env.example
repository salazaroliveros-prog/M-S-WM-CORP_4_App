# Example environment file for local development (do NOT commit secrets)
# Copy to `.env.local` and fill with real values when developing locally.

VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<your-anon-publishable-key>"

# Optional: Web Push (PWA). Public VAPID key used by the browser to subscribe.
# This is NOT a secret.
VITE_WEB_PUSH_PUBLIC_KEY="<your-vapid-public-key>"

# For integration/test helpers (optional):
# SUPABASE_TEST_EMAIL="test@example.com"
# SUPABASE_TEST_PASSWORD="change-me"

# Do NOT put admin or service-role keys here. Keep those in Supabase Project
# Secrets and GitHub repository Secrets.
