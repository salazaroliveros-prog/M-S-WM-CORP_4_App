{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Vite Dev Server",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": {
				"owner": "vite",
				"pattern": [
					{
						"regexp": "^(.*)$",
						"message": 1
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^(> vite|\\s*VITE v)",
					"endsPattern": "(ready in|Local:\\s+http://)"
				}
			},
			"group": "build"
		}
	]
}