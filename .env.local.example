# Optional: Supabase (enables real CRUD + multi-tenant RLS)
# If you don't set these, the app falls back to localStorage.
# IMPORTANT: Use the public ANON key only in the browser. Never put a Service Role key in any VITE_* env var.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Optional: Web Push (PWA). Public VAPID key used by the browser to subscribe.
# This is NOT a secret.
VITE_WEB_PUSH_PUBLIC_KEY="YOUR_VAPID_PUBLIC_KEY"

# Optional: organization name used for multi-tenant bootstrap (defaults to "M&S Construcción")
# In your case you can use your email:
VITE_ORG_NAME="you@example.com"

# Optional but IMPORTANT for multi-device sync:
# If set, all devices will join this exact organization id in Supabase.
# If you leave it empty, each device may create/use a different org and won't see each other's data.
VITE_ORG_ID=""

# Optional (recommended for integration tests): use a real test user instead of anonymous sign-in
# Create this user in Supabase Dashboard → Authentication → Users
SUPABASE_TEST_EMAIL="test@example.com"
SUPABASE_TEST_PASSWORD="12345678"

# Optional: org name used by integration tests (falls back to VITE_ORG_NAME)
SUPABASE_TEST_ORG_NAME="you@example.com"

# Optional: build-time automatic credentials for deployed PWA.
# Set these as GitHub Pages / Actions secrets named exactly as below so
# Vite will embed them at build time (only use a non-privileged user).
# Use the same prefix `VITE_` to include in the client bundle.
VITE_SUPABASE_AUTO_EMAIL="test@example.com"
VITE_SUPABASE_AUTO_PASSWORD="12345678"
